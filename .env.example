# evecre01-node 環境変数テンプレート
# 実際の値は .env に記入する（.env は gitignore 済み・コミット禁止）

# ===== 必須 =====
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net   # MongoDB Atlas 接続文字列
MONGODB_DB=evecre                                          # DB名
COOKIE_SECRET=replace-with-a-long-random-string           # セッションCookie署名用

# ===== Cloudflare R2（画像アップロード: アバター・提出画像）=====
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=
R2_PUBLIC_URL=https://your-bucket.example.com

# ===== Cloudflare Workers AI（ミッション提案の動的生成）=====
# 未設定でも動作する（その場合は自動でテンプレ提案にフォールバック）。
# トークン取得: Cloudflare ダッシュボード → AI → Workers AI → "REST API" / API Tokens で
#   「Workers AI」の実行権限（Account › Workers AI › Edit）を付与したトークンを発行。
CF_ACCOUNT_ID=                              # 任意。未設定なら R2_ACCOUNT_ID を流用
CF_AI_API_TOKEN=                            # Workers AI 実行権限のある API トークン
CF_AI_MODEL=@cf/qwen/qwen3-30b-a3b-fp8      # 任意。未設定ならこの既定モデル

# ===== メール（OTP・パスワードリセット）=====
MAIL_TRANSPORT=
MAIL_FROM=
MAIL_APP_NAME=evecre
GMAIL_USER=
GMAIL_APP_PASSWORD=
RESEND_API_KEY=

# ===== Google サインイン =====
GOOGLE_CLIENT_ID=

# ===== その他 =====
NODE_ENV=development
